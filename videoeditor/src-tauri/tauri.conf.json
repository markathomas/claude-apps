{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VideoEditor",
  "version": "0.1.0",
  "identifier": "dev.videoeditor.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "VideoEditor",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/.cache/videoeditor/**"]
      }
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": ["icons/icon.png"]
  },
  "plugins": {}
}
